{
    "name": "Meeting Reservation Approval",
    "doctype": "Workflow",
    "document_type": "Room Reservation",
    "workflow_state_field": "workflow_state",
    "states": [
        {"state": "Draft", "doc_status": 0, "allow_edit": 1},
        {"state": "Pending Manager Approval", "doc_status": 0, "allow_edit": 1},
        {"state": "Reserved", "doc_status": 1, "allow_edit": 0},
        {"state": "Rejected", "doc_status": 2, "allow_edit": 0},
        {"state": "Cancelled", "doc_status": 2, "allow_edit": 0}
    ],
    "transitions": [
        {
            "transition": "Draft to Pending",
            "from_state": "Draft",
            "to_state": "Pending Manager Approval",
            "allowed_roles": ["Meeting Room User", "Meeting Room Manager"]
        },
        {
            "transition": "Pending to Reserved",
            "from_state": "Pending Manager Approval",
            "to_state": "Reserved",
            "allowed_roles": ["Meeting Room Manager"]
        },
        {
            "transition": "Pending to Rejected",
            "from_state": "Pending Manager Approval",
            "to_state": "Rejected",
            "allowed_roles": ["Meeting Room Manager"]
        },
        {
            "transition": "Reserved to Cancelled",
            "from_state": "Reserved",
            "to_state": "Cancelled",
            "allowed_roles": ["Meeting Room Manager", "System Manager"]
        }
    ]
}
